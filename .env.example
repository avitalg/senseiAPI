# --- Uploads ---
UPLOAD_DIR=uploads
MAX_UPLOAD_BYTES=26214400

# --- Database ---
DATABASE_URL=postgresql+asyncpg://sensei:sensei@localhost:5432/senseiapi

# --- Whisper transcription (local, via faster-whisper; no API key) ---
# Model size: tiny | base | small | medium | large-v3 (larger = better Hebrew, slower).
# The model is downloaded and cached on first use.
WHISPER_MODEL=small
# Device: cpu | cuda | auto
WHISPER_DEVICE=cpu
# Compute type: int8 | int8_float16 | float16 | float32
WHISPER_COMPUTE_TYPE=int8
# Default transcription language (ISO-639-1). Hebrew = he
TRANSCRIBE_LANGUAGE=he

# --- Analysis backend ---
# mock: returns hardcoded data (default, no API key needed)
# gemini: calls Google Gemini (requires GOOGLE_API_KEY)
ANALYZER_BACKEND=mock
GOOGLE_API_KEY=

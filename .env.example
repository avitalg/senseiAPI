# --- Uploads ---
UPLOAD_DIR=uploads
MAX_UPLOAD_BYTES=26214400

# --- Security ---
# ENABLE_SECURITY=true
# Generate with: openssl rand -hex 32
AUTH_TOKEN_SECRET_KEY=2491aaba2613828bb6b7dce2de4c97012082ec4349e4fa523b43083d61847660
# Token TTL: 30 days by default
AUTH_TOKEN_TTL_SECONDS=2592000

# --- Database ---
DATABASE_URL=postgresql+asyncpg://sensei:sensei@localhost:5432/senseiapi
# Seed demo patients/sessions on app startup. Idempotent (deterministic ids) — the
# first deployment populates the DB, later starts are no-ops. Enable in demo/staging.
SEED_ON_STARTUP=false

# --- CORS (comma-separated browser origins for the Sensei frontend) ---
CORS_ORIGINS=http://localhost:3110,http://127.0.0.1:3110

# --- Transcription backend ---
# elevenlabs (default, hosted API) | whisper (local, offline)
TRANSCRIBER_BACKEND=elevenlabs

# --- ElevenLabs Speech-to-Text (required when TRANSCRIBER_BACKEND=elevenlabs) ---
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=scribe_v2

# --- Whisper transcription (local, via faster-whisper; no API key) ---
# Only used when TRANSCRIBER_BACKEND=whisper.
# Model size: tiny | base | small | medium | large-v3 (larger = better Hebrew, slower).
# The model is downloaded and cached on first use.
WHISPER_MODEL=small
# Device: cpu | cuda | auto
WHISPER_DEVICE=cpu
# Compute type: int8 | int8_float16 | float16 | float32
WHISPER_COMPUTE_TYPE=int8
# Default transcription language (ISO-639-1). Hebrew = he
TRANSCRIBE_LANGUAGE=he

# --- Text-to-speech (ElevenLabs, optional) ---
# Reuses ELEVENLABS_API_KEY above. A voice ID is required when enabled.
TTS_ENABLED=false
TTS_BACKEND=elevenlabs
ELEVENLABS_TTS_MODEL=eleven_v3
ELEVENLABS_TTS_VOICE_ID=
# ISO-639-1 language code. Hebrew = he
TTS_DEFAULT_LANGUAGE=he
# Supported range: 0.7 to 1.2
TTS_DEFAULT_SPEED=1.0
# mp3 (44.1 kHz, 128 kbps) | mp3_fast (22.05 kHz, 32 kbps) | wav
TTS_DEFAULT_OUTPUT_FORMAT=mp3_fast
TTS_MAX_TEXT_CHARS=5000
TTS_TIMEOUT_SECONDS=30

# --- Chat assistant ("שאל את סנסיי", hosted OpenAI) ---
# Powers the free-form therapist chat. Unlike summaries (kept local), this uses the
# hosted OpenAI API. Set ASSISTANT_ENABLED=false to turn the /assistant/chat endpoint off.
ASSISTANT_ENABLED=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# Where the assistant's tools fetch context from (this API itself).
ASSISTANT_SELF_BASE_URL=http://localhost:8000
# true = the assistant may GET ANY endpoint on this API (incl. PHI) — demo only.
# false (default) = restricted to the PHI-safe /assistant/context/* surface.
ASSISTANT_ALLOW_ALL_GETS=false
# Size caps: max tokens generated per answer, max chars for one user question, and a
# ceiling on the whole prompt (system + history + tool results) — oldest history is
# dropped to fit.
ASSISTANT_MAX_OUTPUT_TOKENS=2000
ASSISTANT_MAX_QUESTION_CHARS=2000
ASSISTANT_MAX_TOTAL_INPUT_TOKENS=50000

# --- Session summaries (local Ollama; transcripts never leave this host) ---
# Requires: ollama pull llama3.1:latest
SUMMARY_ENABLED=true
OLLAMA_HOST=http://localhost:11434
#OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_MODEL=llama3.1:latest
# Ollama defaults num_ctx to 2048 and SILENTLY truncates longer input, which would
# summarise only the opening minutes of a session. Keep this explicit.
OLLAMA_NUM_CTX=32768
OLLAMA_TIMEOUT_SECONDS=600
# Transcripts longer than this fail loudly rather than being silently truncated.
MAX_TRANSCRIPT_CHARS=40000
